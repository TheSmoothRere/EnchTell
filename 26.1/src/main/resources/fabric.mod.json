{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}+${minecraftVersion}",
  "name": "${name}",
  "description": "${description}",
  "icon": "assets/${id}/icon.png",
  "license": "${license}",
  "authors": [
    "${author}"
  ],
  "contact": {
    "homepage":"https://github.com/TheSmoothRere/EnchTell",
    "source": "https://github.com/TheSmoothRere/EnchTell",
    "issues": "https://github.com/TheSmoothRere/EnchTell/issues"
  },
  "environment": "client",
  "entrypoints": {
    "main": [
      "io.github.thesmoothrere.enchtell.EnchTell"
    ],
    "client": [
      "io.github.thesmoothrere.enchtell.client.EnchTellClient"
    ],
    "relib": [
      "io.github.thesmoothrere.enchtell.config.EnchTellConfig"
    ]
  },
  "depends": {
    "minecraft": ">=${minecraftVersion}",
    "java": "~${javaVersion}",
    "relib": ">=0.1.1+26.1",
    "fabric-api": ">=${fabricApiVersion}"
  }
}
